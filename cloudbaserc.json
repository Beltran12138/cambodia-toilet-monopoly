{
  "envId": "theway-2gfdpspmc0387027",
  "functionRoot": "./functions",
  "functions": [],
  "hosting": {
    "outputDirectory": "dist",
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      },
      {
        "source": "**/*.@(html|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "ignore": [".git", ".git/**", "node_modules", ".env", ".env.local"]
  },
  "ai": {
    "defaultAgent": "claude",
    "agents": {
      "claude": {
        "type": "custom",
        "baseUrl": "https://api.anthropic.com",
        "apiKey": ""
      }
    }
  }
}
